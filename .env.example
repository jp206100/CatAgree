# ─── Convex ───────────────────────────────────────────────────────────────────
# Found in your Convex dashboard after running `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# The Convex HTTP actions base URL (ends in .convex.site)
CONVEX_SITE_URL=https://<your-deployment>.convex.site

# Your Next.js app's public URL — used by:
#   1. Convex Auth, to redirect back after Google OAuth
#   2. The launch action, to build participant magic-link URLs
#      (https://<SITE_URL>/p/<token>)
# In production: your Vercel URL. In dev: http://localhost:3000
SITE_URL=https://<your-app>.vercel.app

# ─── Convex Auth ──────────────────────────────────────────────────────────────
# Generate an RSA-2048 private key in PKCS8 PEM format:
#   node -e "const {privateKey}=require('crypto').generateKeyPairSync('rsa',{modulusLength:2048});console.log(privateKey.export({type:'pkcs8',format:'pem'}))"
# Paste the ENTIRE multi-line output (including BEGIN/END lines) into
# Convex dashboard → Settings → Environment Variables → JWT_PRIVATE_KEY
JWT_PRIVATE_KEY=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://<your-deployment>.convex.site/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Resend (email — Convex env, NOT here / NOT Vercel) ───────────────────────
# The launch action calls Resend from inside Convex's runtime, so this key
# lives ONLY in the Convex deployment env. Do not add it to .env.local or
# Vercel; it would have no effect.
#   npx convex env set RESEND_API_KEY re_xxx              # dev deployment
#   npx convex env set --prod RESEND_API_KEY re_xxx       # production
# Get a key: https://resend.com/api-keys
# (No line below — intentionally not a Next.js env var.)
